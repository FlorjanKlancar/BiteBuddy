# Ports (override defaults from @bitebuddy/shared PORTS config)
PORT_WEB=3000
PORT_API=3001
PORT_DB=5432

# Database
DATABASE_URL=postgresql://bitebuddy:bitebuddy@localhost:5432/bitebuddy

# Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
# Comma-separated list of allowed origins for CORS (defaults to localhost web port)
FRONTEND_URL=http://localhost:3000
